{
  "name": "student-management-backend-mysql",
  "version": "1.0.0",
  "description": "Backend for Student Management System with MySQL",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:clean": "npm run clean && npm run build",
    "clean": "rm -rf dist",
    "start": "node start.js",
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/server.ts",
    "prod": "npm run build && npm start",
    "verify": "node -e \"console.log('Node version:', process.version); console.log('Platform:', process.platform);\"",
    "typeorm": "typeorm-ts-node-commonjs",
    "migrate:fresh": "ts-node -r tsconfig-paths/register ./src/scripts/migration-fresh.ts",
    "seed": "ts-node -r tsconfig-paths/register ./src/seeds/seed.ts",
    "seed:dummy": "ts-node -r tsconfig-paths/register ./src/seeds/seedDummyData.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^10.0.0",
    "@types/nodemailer": "^6.4.17",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "express-session": "^1.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jose": "^6.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "mysql2": "^3.6.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^21.0.0",
    "reflect-metadata": "^0.1.14",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.26",
    "typeorm-extension": "^3.7.1",
    "typescript": "^5.1.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.5.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1",
    "timestamp": "^0.0.1"
  }
}
