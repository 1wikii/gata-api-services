NODE_ENV=development
PORT=5000

# MySQL Database Configuration
DB_TYPE=
DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_NAME=

# Admin Configuration
ADMIN_EMAIL=
ADMIN_PASSWORD=

# JWT Configuration
JWT_SECRET=your-very-strong-secret-here
JWT_EXPIRES_IN=7d  
BCRYPT_SALT_ROUNDS=12

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Database Options
DB_SYNC=false
DB_LOGGING=true

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Frontend URL untuk reset password link & CORS
# Development: http://localhost:3000
# Production: https://gata.web.id
FRONTEND_URL=http://localhost:3000

# Production Backend URL (untuk redirect setelah login)
BACKEND_URL=http://localhost:5000